# Jira — required for fetching commit metadata
# Generate your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://redhat.atlassian.net
JIRA_USERNAME=your-email@redhat.com
JIRA_API_TOKEN=your-jira-api-token

# GitHub — for API rate limiting (optional but recommended)
# Without a token: 60 requests/hour. With a token: 5,000 requests/hour.
# Generate at: https://github.com/settings/tokens (select scope: public_repo)
GITHUB_TOKEN=ghp_your_token_here

# GitLab — required for app-interface automation
# Token scopes needed: api + write_repository
# Generate at: https://gitlab.cee.redhat.com/-/user_settings/personal_access_tokens
GITLAB_TOKEN=glpat-your_token_here
GITLAB_BASE_URL=https://gitlab.cee.redhat.com

# Fork + upstream app-interface projects in GitLab path format: group/subgroup/project
APP_INTERFACE_FORK_PROJECT=your-username/app-interface
APP_INTERFACE_UPSTREAM_PROJECT=service/app-interface
APP_INTERFACE_TARGET_BRANCH=master

# Claude Code AI summary — optional, OFF by default
# When enabled, bump-brat resumes this existing local Claude Code session to generate
# a short 1-2 sentence summary from commit messages and adds it to MR descriptions.
BUMP_BRAT_USE_CLAUDE_SUMMARY=false
# Optional: when set, bump-brat calls `claude --resume <id>`; otherwise it uses
# your default local Claude auth/session context.
BUMP_BRAT_CLAUDE_SESSION_ID=
# Optional overrides:
# BUMP_BRAT_CLAUDE_BIN=claude
# BUMP_BRAT_CLAUDE_SUMMARY_TIMEOUT_SECONDS=60

# Slack — for posting JIRA tickets to Slack workflows (optional)
# Generate a webhook URL for your Slack workflow
SLACK_WEBHOOK_URL=https://hooks.slack.com/triggers/YOUR_WORKSPACE/YOUR_TRIGGER_ID/YOUR_TOKEN

